# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# ─── Payload ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (plain postgres):
DATABASE_URL=postgresql://clasificados:yourpassword@localhost:5432/clasificados
# Docker Compose:
# DATABASE_URL=postgresql://clasificados:yourpassword@postgres:5432/clasificados
# Coolify internal URL (services on same network reach each other by container name):
# DATABASE_URL=postgres://postgres:PASSWORD@postgresql-database-es369mpez7rw7w038wvlla9b:5432/postgres

POSTGRES_USER=clasificados
POSTGRES_PASSWORD=yourpassword

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev:
REDIS_URL=redis://:yourredispassword@localhost:6379
# Docker Compose:
# REDIS_URL=redis://:yourredispassword@redis:6379
REDIS_PASSWORD=yourredispassword

# ─── Meilisearch ──────────────────────────────────────────────────────────────
# Local dev:
MEILI_URL=http://localhost:7700
# Docker Compose:
# MEILI_URL=http://meilisearch:7700
# Generate with: openssl rand -hex 16
MEILI_MASTER_KEY=your_meilisearch_master_key

# ─── Cloudflare R2 (Image Storage) ────────────────────────────────────────────
# Leave blank to use local /public/media storage during development
R2_BUCKET=clasificados-media
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.clasificadospr.com

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
